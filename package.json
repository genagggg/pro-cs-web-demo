{
  "name": "pro-cs-web-demo",
  "version": "1.0.0",
  "description": "Enterprise logistics system monorepo",
  "private": true,
  "workspaces": [
    "host",
    "remote-radar", 
    "remote-offers",
    "mock-server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:host\" \"npm run dev:radar\" \"npm run dev:offers\" \"npm run dev:mock\"",
    "dev:host": "npm run dev --workspace=host",
    "dev:radar": "npm run dev --workspace=remote-radar",
    "dev:offers": "npm run dev --workspace=remote-offers",
    "dev:mock": "npm run dev --workspace=mock-server",
    "build": "npm run build --workspaces",
    "clean": "rimraf node_modules && npm run clean --workspaces",
    "clean:all": "rimraf node_modules && rimraf host/node_modules && rimraf remote-radar/node_modules && rimraf remote-offers/node_modules && rimraf mock-server/node_modules",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx --max-warnings 0 .",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.jsx --fix --max-warnings 0 .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,html,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,html,css,scss}\"",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests configured — install Jest to enable'",
    "deploy": "vercel --prod",
    "deploy:host": "vercel --prod --cwd host",
    "deploy:radar": "vercel --prod --cwd remote-radar",
    "deploy:offers": "vercel --prod --cwd remote-offers",
    "deploy:mock": "vercel --prod --cwd mock-server"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "concurrently": "^8.2.2",
    "dotenv-webpack": "^8.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.6.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}